{
  "name": "@esbenwiberg/repofit",
  "version": "1.0.0",
  "description": "Measure how agent-friendly your repo is.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "repofit": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "default": "./dist/sdk/index.js"
    },
    "./sdk/recipes": {
      "types": "./dist/sdk/recipes/index.d.ts",
      "default": "./dist/sdk/recipes/index.js"
    }
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.19.18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.2",
    "commander": "^14.0.3",
    "ignore": "^7.0.5"
  }
}
